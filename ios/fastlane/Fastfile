default_platform(:ios)

require "base64"

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: "XX5239JSR5",
      issuer_id: ENV["APPLE_ISSUER_ID"],
      key_filepath: "fastlane/AuthKey_XX5239JSR5.p8"
    )

    build_number = ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")

    # 使用绝对路径，避免 fastlane CWD 切换导致找不到文件
    ios_dir = File.expand_path("..", __dir__)  # __dir__ = ios/fastlane/
    app_dir = File.join(ios_dir, "App")
    xcodeproj_path = File.join(app_dir, "App.xcodeproj")
    package_swift = File.join(app_dir, "CapApp-SPM", "Package.swift")
    build_dir = File.join(ios_dir, "build")

    # 诊断
    UI.message("ios_dir: #{ios_dir}")
    UI.message("app_dir: #{app_dir}")
    if File.directory?(app_dir)
      UI.message("App/ 目录内容:")
      Dir.children(app_dir).each { |f| UI.message("  #{f}") }
    else
      UI.error("App/ 目录不存在！")
      UI.message("ios_dir 内容:")
      Dir.children(ios_dir).each { |f| UI.message("  #{f}") } if File.directory?(ios_dir)
    end

    # 确保 xcodeproj 存在
    unless File.directory?(xcodeproj_path)
      UI.error("App.xcodeproj 不存在！重新运行 cap sync ios ...")
      Dir.chdir(File.expand_path("../..", __dir__)) do
        sh("npx", "cap", "sync", "ios")
      end
      unless File.directory?(xcodeproj_path)
        UI.user_error!("App/App.xcodeproj 仍然不存在，构建中止")
      end
    end

    # 适配 Xcode 16 (最低部署目标 16.0)
    if File.exist?(package_swift)
      content = File.read(package_swift)
      if content.match?(/\.iOS\(\.v1[789]\)/)
        UI.message("修正 Package.swift iOS 版本...")
        sh("sed", "-i", "", "s/\\.iOS(\\.v1[789])/.iOS(.v16)/g", package_swift)
      end
    end

    FileUtils.mkdir_p(build_dir)

    # 在 login keychain 中查找可用的分发证书
    login_keychain = File.expand_path("~/Library/Keychains/login.keychain-db")
    ci_keychain = File.expand_path("~/Library/Keychains/ci-build.keychain-db")

    login_dist_certs = `security find-identity -v -p codesigning #{login_keychain} 2>&1`.scan(/Apple Distribution/).size
    ci_dist_certs = `security find-identity -v -p codesigning #{ci_keychain} 2>&1`.scan(/Apple Distribution/).size
    UI.message("login keychain 分发证书: #{login_dist_certs}, CI keychain 分发证书: #{ci_dist_certs}")

    # 选择包含分发证书的 keychain 作为签名 keychain
    if ci_dist_certs > 0
      signing_keychain = ci_keychain
    elsif login_dist_certs > 0
      signing_keychain = login_keychain
    else
      UI.user_error!("未找到 Apple Distribution 证书，请先导入到 keychain")
    end
    UI.message("使用签名 keychain: #{signing_keychain}")

    # 使用 sigh 通过 App Store Connect API 下载分发 provisioning profile
    UI.message("下载分发 provisioning profile...")
    begin
      get_provisioning_profile(
        api_key: api_key,
        app_identifier: "com.mfcr7788.lingji",
        readonly: true,
        skip_certificate_verification: true
      )
    rescue => e
      UI.message("只读获取失败: #{e.message}，尝试创建/修复 profile...")
      get_provisioning_profile(
        api_key: api_key,
        app_identifier: "com.mfcr7788.lingji",
        skip_certificate_verification: true
      )
    end

    profile_uuid = lane_context[SharedValues::SIGH_UUID]
    UI.user_error!("未能获取 provisioning profile UUID") if profile_uuid.nil? || profile_uuid.empty?
    UI.message("Provisioning profile UUID: #{profile_uuid}")

    # Archive — 跳过签名 (SPM 库不支持 provisioning profile)
    # 所有签名在 export 阶段完成
    key_path = File.expand_path("AuthKey_XX5239JSR5.p8", __dir__)
    sh("xcodebuild", "archive",
       "-project", xcodeproj_path,
       "-scheme", "App",
       "-archivePath", File.join(build_dir, "App.xcarchive"),
       "-destination", "generic/platform=iOS",
       "-authenticationKeyIssuerID", ENV["APPLE_ISSUER_ID"],
       "-authenticationKeyID", "XX5239JSR5",
       "-authenticationKeyPath", key_path,
       "DEVELOPMENT_TEAM=698S6LL5G6",
       "CODE_SIGNING_REQUIRED=NO",
       "CODE_SIGNING_ALLOWED=NO",
       "CURRENT_PROJECT_VERSION=#{build_number}",
       "IPHONEOS_DEPLOYMENT_TARGET=16.0"
    )

    # 创建 exportOptions.plist — 手动签名
    require 'plist'
    File.write(File.join(build_dir, "exportOptions.plist"), {
      method: "app-store-connect",
      signingStyle: "manual",
      destination: "upload",
      teamID: "698S6LL5G6",
      signingCertificate: "Apple Distribution",
      provisioningProfiles: { "com.mfcr7788.lingji": profile_uuid }
    }.to_plist)

    # 将签名 keychain 加入搜索列表，确保 xcodebuild 能找到分发证书签名
    original_keychains = `security list-keychains -d user`.strip
    UI.message("原 keychain 搜索列表: #{original_keychains}")
    sh("security", "list-keychains", "-d", "user", "-s", "#{signing_keychain}", "#{login_keychain}")

    begin
      # Export archive to IPA — 加 auth flags 解决 "Failed to Use Accounts"
      sh("xcodebuild", "-exportArchive",
         "-archivePath", File.join(build_dir, "App.xcarchive"),
         "-exportPath", build_dir,
         "-exportOptionsPlist", File.join(build_dir, "exportOptions.plist"),
         "-authenticationKeyIssuerID", ENV["APPLE_ISSUER_ID"],
         "-authenticationKeyID", "XX5239JSR5",
         "-authenticationKeyPath", key_path
      )
    ensure
      # 恢复原 keychain 搜索列表
      sh("security", "list-keychains", "-d", "user", "-s", *original_keychains.split(/\s+/).reject(&:empty?))
    end

    # Upload IPA to TestFlight
    upload_to_testflight(
      ipa: File.join(build_dir, "App.ipa"),
      skip_waiting_for_build_processing: true,
      api_key: api_key
    )
  end
end
