default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: "52H698RFZF",
      issuer_id: ENV["APPLE_ISSUER_ID"],
      key_filepath: "fastlane/AuthKey_52H698RFZF.p8"
    )

    match(
      type: "appstore",
      readonly: true,
      app_identifier: "com.mfcr7788.lingji",
      api_key: api_key
    )

    # Allow xcodebuild to access signing keys without prompting (required for CI)
    if ENV["MATCH_KEYCHAIN_NAME"]
      sh("security", "set-key-partition-list", "-S", "apple-tool:,apple:", "-s", "-k", ENV["MATCH_KEYCHAIN_PASSWORD"], ENV["MATCH_KEYCHAIN_NAME"])
    end

    build_number = ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")

    build_app(
      scheme: "App",
      project: "App/App.xcodeproj",
      export_method: "app-store",
      output_directory: "./build",
      include_symbols: true,
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number} IPHONEOS_DEPLOYMENT_TARGET=16.0"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key: api_key
    )
  end
end
