default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: "52H698RFZF",
      issuer_id: ENV["APPLE_ISSUER_ID"],
      key_filepath: "fastlane/AuthKey_52H698RFZF.p8"
    )

    build_number = ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")

    # Create export options for automatic signing
    require 'plist'
    FileUtils.mkdir_p("build")
    File.write("build/exportOptions.plist", {
      method: "app-store",
      signingStyle: "automatic",
      destination: "upload",
      teamID: "698S6LL5G6"
    }.to_plist)

    # Archive with automatic signing (no match, no keychain management)
    key_path = File.join(__dir__, "AuthKey_52H698RFZF.p8")
    sh("xcodebuild", "archive",
       "-project", "App/App.xcodeproj",
       "-scheme", "App",
       "-archivePath", "build/App.xcarchive",
       "-destination", "generic/platform=iOS",
       "-allowProvisioningUpdates",
       "-authenticationKeyIssuerID", ENV["APPLE_ISSUER_ID"],
       "-authenticationKeyID", "52H698RFZF",
       "-authenticationKeyPath", key_path,
       "CURRENT_PROJECT_VERSION=#{build_number}",
       "IPHONEOS_DEPLOYMENT_TARGET=16.0"
    )

    # Export archive to IPA
    sh("xcodebuild", "-exportArchive",
       "-archivePath", "build/App.xcarchive",
       "-exportPath", "build",
       "-exportOptionsPlist", "build/exportOptions.plist",
       "-allowProvisioningUpdates",
       "-authenticationKeyIssuerID", ENV["APPLE_ISSUER_ID"],
       "-authenticationKeyID", "52H698RFZF",
       "-authenticationKeyPath", key_path
    )

    # Upload IPA to TestFlight
    upload_to_testflight(
      ipa: "build/App.ipa",
      skip_waiting_for_build_processing: true,
      api_key: api_key
    )
  end
end
