default_platform(:ios)

require "base64"

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: "XX5239JSR5",
      issuer_id: ENV["APPLE_ISSUER_ID"],
      key_filepath: "fastlane/AuthKey_XX5239JSR5.p8"
    )

    build_number = ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")

    # 使用绝对路径，避免 fastlane CWD 切换导致找不到文件
    ios_dir = File.expand_path("..", __dir__)  # __dir__ = ios/fastlane/
    app_dir = File.join(ios_dir, "App")
    xcodeproj_path = File.join(app_dir, "App.xcodeproj")
    package_swift = File.join(app_dir, "CapApp-SPM", "Package.swift")
    build_dir = File.join(ios_dir, "build")

    # 诊断
    UI.message("ios_dir: #{ios_dir}")
    UI.message("app_dir: #{app_dir}")
    if File.directory?(app_dir)
      UI.message("App/ 目录内容:")
      Dir.children(app_dir).each { |f| UI.message("  #{f}") }
    else
      UI.error("App/ 目录不存在！")
      UI.message("ios_dir 内容:")
      Dir.children(ios_dir).each { |f| UI.message("  #{f}") } if File.directory?(ios_dir)
    end

    # 确保 xcodeproj 存在
    unless File.directory?(xcodeproj_path)
      UI.error("App.xcodeproj 不存在！重新运行 cap sync ios ...")
      Dir.chdir(File.expand_path("../..", __dir__)) do
        sh("npx", "cap", "sync", "ios")
      end
      unless File.directory?(xcodeproj_path)
        UI.user_error!("App/App.xcodeproj 仍然不存在，构建中止")
      end
    end

    # 适配 Xcode 16 (最低部署目标 16.0)
    if File.exist?(package_swift)
      content = File.read(package_swift)
      if content.match?(/\.iOS\(\.v1[789]\)/)
        UI.message("修正 Package.swift iOS 版本...")
        sh("sed", "-i", "", "s/\\.iOS(\\.v1[789])/.iOS(.v16)/g", package_swift)
      end
    end

    FileUtils.mkdir_p(build_dir)
    key_path = File.expand_path("AuthKey_XX5239JSR5.p8", __dir__)

    # 创建临时 keychain 用于存放分发证书
    keychain_name = "fastlane_tmp_keychain"
    keychain_password = "fastlane_tmp_password"
    keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}-db")

    if File.exist?(keychain_path)
      sh("security", "delete-keychain", keychain_name) rescue nil
    end
    sh("security", "create-keychain", "-p", keychain_password, keychain_name)
    sh("security", "unlock-keychain", "-p", keychain_password, keychain_name)
    sh("security", "list-keychains", "-d", "user", "-s", keychain_name, "login.keychain-db")
    sh("security", "default-keychain", "-s", keychain_name)
    sh("security", "set-keychain-settings", "-t", "3600", "-u", keychain_name)

    # 从 GitHub Secrets 解码 .p12 分发证书，导入到临时 keychain
    p12_path = File.join(build_dir, "distribution.p12")
    File.write(p12_path, Base64.decode64(ENV["DISTRIBUTION_CERT_P12"]))
    sh("security", "import", p12_path,
       "-k", keychain_path,
       "-P", ENV["DISTRIBUTION_CERT_PASSWORD"],
       "-A")
    File.delete(p12_path)

    # Archive — -allowProvisioningUpdates 创建 provisioning profile
    sh("xcodebuild", "archive",
       "-project", xcodeproj_path,
       "-scheme", "App",
       "-archivePath", File.join(build_dir, "App.xcarchive"),
       "-destination", "generic/platform=iOS",
       "-allowProvisioningUpdates",
       "-authenticationKeyIssuerID", ENV["APPLE_ISSUER_ID"],
       "-authenticationKeyID", "XX5239JSR5",
       "-authenticationKeyPath", key_path,
       "DEVELOPMENT_TEAM=698S6LL5G6",
       "CURRENT_PROJECT_VERSION=#{build_number}",
       "IPHONEOS_DEPLOYMENT_TARGET=16.0"
    )

    # 找到 archive 步骤创建的 provisioning profile
    provisioning_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    profile_uuid = nil

    # 先检查 provisioning profiles 目录
    if Dir.exist?(provisioning_dir)
      UI.message("Provisioning Profiles 目录内容:")
      Dir.glob(File.join(provisioning_dir, "*.mobileprovision")).each do |f|
        content = %x(/usr/bin/security cms -D -i "#{f}" 2>/dev/null)
        if content.include?("com.mfcr7788.lingji")
          uuid = %x(/usr/bin/security cms -D -i "#{f}" 2>/dev/null | /usr/bin/plutil -extract UUID raw - 2>/dev/null).strip
          UI.message("找到 profile: #{uuid}")
          profile_uuid = uuid
          break
        end
      end
    else
      UI.message("Provisioning Profiles 目录不存在")
    end

    # 如果目录里没有，尝试从 xcarchive 中提取
    if profile_uuid.nil?
      UI.message("从 xcarchive 提取 provisioning profile...")
      embedded_profile = File.join(build_dir, "App.xcarchive", "Products", "Applications", "App.app", "embedded.mobileprovision")
      if File.exist?(embedded_profile)
        content = %x(/usr/bin/security cms -D -i "#{embedded_profile}" 2>/dev/null)
        uuid = %x(/usr/bin/security cms -D -i "#{embedded_profile}" 2>/dev/null | /usr/bin/plutil -extract UUID raw - 2>/dev/null).strip
        UI.message("从 xcarchive 提取到 UUID: #{uuid}")

        # 复制到 provisioning profiles 目录
        FileUtils.mkdir_p(provisioning_dir)
        dest = File.join(provisioning_dir, "#{uuid}.mobileprovision")
        FileUtils.cp(embedded_profile, dest)
        profile_uuid = uuid
      end
    end

    UI.user_error!("未找到 com.mfcr7788.lingji 的 provisioning profile") if profile_uuid.nil? || profile_uuid.empty?

    # 创建 exportOptions.plist — 手动签名，指定证书和 profile
    require 'plist'
    File.write(File.join(build_dir, "exportOptions.plist"), {
      method: "app-store-connect",
      signingStyle: "manual",
      destination: "upload",
      teamID: "698S6LL5G6",
      signingCertificate: "Apple Distribution",
      provisioningProfiles: { "com.mfcr7788.lingji": profile_uuid }
    }.to_plist)

    # Export archive to IPA — 手动签名，不需要网络认证
    sh("xcodebuild", "-exportArchive",
       "-archivePath", File.join(build_dir, "App.xcarchive"),
       "-exportPath", build_dir,
       "-exportOptionsPlist", File.join(build_dir, "exportOptions.plist")
    )

    # Upload IPA to TestFlight
    upload_to_testflight(
      ipa: File.join(build_dir, "App.ipa"),
      skip_waiting_for_build_processing: true,
      api_key: api_key
    )
  end
end
