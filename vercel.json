{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/ai/video/one-click/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/ai/video/merge/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/ai/video/generate/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/ai/extract-video-text/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/cron/check-hotspots/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/cron/cleanup-hotspots/route.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "src/app/api/cron/credits-reset/route.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "src/app/api/cron/subscription-grant/route.ts": {
      "maxDuration": 120,
      "memory": 512
    },
    "src/app/api/platforms/metrics-fetch/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/platforms/scheduled-publish/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/check-hotspots",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/jobs/claim",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/platforms/metrics-fetch",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/platforms/scheduled-publish",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/credits-reset",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/subscription-grant",
      "schedule": "0 16 * * *"
    }
  ]
}
