# 灵集 - 环境变量配置模板
# 复制此文件为 .env.local 并填入真实值
# 注意：.env.local 文件不要提交到 Git 仓库！

# ==========================================
# AI 服务
# ==========================================

# DeepSeek API - 文本生成
DEEPSEEK_API_KEY=your_deepseek_api_key

# 火山引擎（豆包）API - 多模态理解、生图、生视频
# 豆包视觉理解
DOUBAO_API_KEY=your_doubao_api_key
# Seedance 生成视频模型（Doubao-Seedance-1.5-pro）
SEEDANCE_VIDEO_MODEL_ARK_ID=your_seedance_video_model_ark_id
# Seedream 生成图片模型（Doubao-Seedream-5.0-lite）
SEEDANCE_IMAGE_MODEL_ARK_ID=your_seedance_image_model_ark_id

# OpenRouter API - 热点抓取、多模型接入（备用）
OPENROUTER_API_KEY=your_openrouter_api_key

# ElevenLabs API - 语音合成（TTS）
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ==========================================
# 数据库和认证
# ==========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# ==========================================
# 存储和短信服务
# ==========================================

# 阿里云 SMS - 短信验证码
ALIYUN_SMS_ACCESS_KEY_ID=your_aliyun_sms_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_aliyun_sms_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=your_sms_template_code
ALIYUN_SMS_REGION_ID=cn-hangzhou
# 模板内容：您的验证码为：${code}，该验证码5分钟内有效，请勿泄露于他人！——灵集

# ==========================================
# Supabase Storage - 文件存储（替代阿里云 OSS）
# ==========================================
# Supabase 自带 Storage 服务，无需额外配置
# 在代码中使用 @supabase/storage-js 即可

# ==========================================
# 支付服务（第二阶段）
# ==========================================

# 微信支付
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_PATH=

# ==========================================
# 多平台分发 V2.0.2（OAuth + 发布）
# ==========================================

# Token 加密密钥（32 字节 hex）— 用 `openssl rand -hex 32` 生成
PLATFORM_ENCRYPTION_KEY=

# Cron 端点鉴权（Vercel cron 调用 /api/jobs/claim 和 /api/platforms/metrics-fetch 用）
CRON_SECRET=your-cron-secret-here

# 微信公众号开放平台
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=

# 微博开放平台
WEIBO_APP_KEY=
WEIBO_APP_SECRET=

# ==========================================
# 应用配置
# ==========================================

# 站点 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT 密钥（用于签名，生产环境请更换为强密码）
JWT_SECRET=your-secret-key-here-change-in-production
