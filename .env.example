# 灵集 - 环境变量配置模板
# 复制此文件为 .env.local 并填入真实值
# 注意：.env.local 文件不要提交到 Git 仓库！

# ==========================================
# AI 服务
# ==========================================

# DeepSeek API - 文本生成
DEEPSEEK_API_KEY=your_deepseek_api_key

# 火山引擎（豆包）API - 多模态理解、生图、生视频
# 豆包视觉理解
DOUBAO_API_KEY=your_doubao_api_key
# Seedance 生成视频模型（Doubao-Seedance-1.5-pro）
SEEDANCE_VIDEO_MODEL_ARK_ID=your_seedance_video_model_ark_id
# Seedream 生成图片模型（Doubao-Seedream-5.0-lite）
SEEDANCE_IMAGE_MODEL_ARK_ID=your_seedance_image_model_ark_id

# OpenRouter API - 热点抓取、多模型接入（备用）
OPENROUTER_API_KEY=your_openrouter_api_key

# ElevenLabs API - 语音合成（TTS）
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# 阿里云 DashScope API - 通义千问 / HappyHorse 视频生成
# 从 https://dashscope.console.aliyun.com/apiKey 获取
DASHSCOPE_API_KEY=your_dashscope_api_key

# 本地 FunASR 语音识别服务 (自部署，可选)
# 留空则使用 DashScope Paraformer 云 API
FUNASR_API_URL=http://localhost:10096

# 本地 Kokoro TTS 语音合成 (自部署，可选)
# 留空则使用 DashScope CosyVoice 云 API
KOKORO_API_URL=http://localhost:8880

# jina.ai Reader - 链接正文抓取(微信公众号/知乎/小红书等 SPA 必备)
# 免费版 20 RPM,设 key 后 200 RPM
# 申请:https://jina.ai/reader/  (留空也能用,只是慢)
JINA_API_KEY=

# ==========================================
# 数据库和认证
# ==========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# Auth 盐(用于手机号登录的 deterministic password)
# 用 `openssl rand -hex 32` 生成 64 字符 hex
# 重要:首次上线后此值不可变更,否则所有用户密码失效
AUTH_SALT=your-auth-salt-here-change-in-production

# ==========================================
# 存储和短信服务
# ==========================================

# 阿里云 SMS - 短信验证码
ALIYUN_SMS_ACCESS_KEY_ID=your_aliyun_sms_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_aliyun_sms_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=your_sms_template_code
ALIYUN_SMS_REGION_ID=cn-hangzhou
# 模板内容：您的验证码为：${code}，该验证码5分钟内有效，请勿泄露于他人！——灵集

# ==========================================
# Supabase Storage - 文件存储（替代阿里云 OSS）
# ==========================================
# Supabase 自带 Storage 服务，无需额外配置
# 在代码中使用 @supabase/storage-js 即可

# ==========================================
# 支付服务（第二阶段）
# ==========================================

# 微信支付
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_PATH=

# ==========================================
# 多平台分发 V2.0.2（OAuth + 发布）
# ==========================================

# Token 加密密钥（32 字节 hex）— 用 `openssl rand -hex 32` 生成
PLATFORM_ENCRYPTION_KEY=

# Cron 端点鉴权（Vercel cron 调用 /api/jobs/claim 和 /api/platforms/metrics-fetch 用）
CRON_SECRET=your-cron-secret-here

# 微信公众号开放平台
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=

# 微博开放平台
WEIBO_APP_KEY=
WEIBO_APP_SECRET=

# ==========================================
# ==========================================
# 开发与安全
# ==========================================

# 启用 dev auth 快捷路径（仅开发环境生效）
# 生产环境(NODE_ENV=production)下此代码块永不执行
# 设为 false 可在开发构建中强制禁用 dev auth
ENABLE_DEV_AUTH=true

# Dev auth 密钥（可选，配置后必须携带才能使用 dev auth）
# 留空时 dev auth 仅允许 localhost IP
DEV_AUTH_SECRET=

# 站点 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT 密钥（用于签名，生产环境请更换为强密码）
JWT_SECRET=your-secret-key-here-change-in-production

# ==========================================
# MCP Server 配置（可选）
# ==========================================

# GitHub Personal Access Token（用于 GitHub MCP Server）
# 创建地址: https://github.com/settings/tokens
# 权限: repo (私有仓库) 或 public_repo (公开仓库)
GITHUB_PERSONAL_ACCESS_TOKEN=

# MCP Servers JSON 配置（高级用法，覆盖默认配置）
# MCP_SERVERS=[{"name":"github","transport":"stdio","command":"npx","args":["-y","@anthropic/mcp-server-github"],"enabled":true}]

# ==========================================
# 视频渲染服务（42 ECS）
# ==========================================

# Revideo 渲染服务（MIT 许可，无水印）
# REVIDEO_RENDER_URL=http://42.121.219.223:3101
# REVIDEO_SECRET=your_revideo_secret

# Remotion 渲染服务（商业许可，带水印）
# REMOTION_RENDER_URL=http://42.121.219.223:3100
# REMOTION_SECRET=your_remotion_secret

# Agnes AI — 免费全模态 API（OpenAI 兼容）
# 注册地址: https://platform.agnes-ai.com
AGNES_API_KEY=your_agnes_api_key
